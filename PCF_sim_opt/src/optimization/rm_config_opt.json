  "validation_rules": {
    "required_fields": [
      "objective",
      "decision_vars",
      "constraints"
    ],
    "valid_objectives": [
      "minimize_carbon",
      "minimize_cost",
      "maximize_ease",
      "multi_objective"
    ],
    "cathode_type_requirements": {
      "A": [
        "recycle_ratio_fixed",
        "low_carbon_ratio_fixed", 
        "emission_range"
      ],
      "B": [
        "emission_fixed",
        "recycle_range",
        "low_carbon_range"
      ]
    },
    "constraint_minimums": {
      "target_carbon": 10.0,
      "max_activities": 1,
      "max_cost": 1000
